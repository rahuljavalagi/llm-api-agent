GOOGLE_API_KEY=
DATABASE_URL=sqlite:///./app.db
PASSWORD_PEPPER=change-this-pepper
SESSION_DAYS=30
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Legacy-only (active vector search now uses SQL/pgvector):
CHROMA_DB_PATH=./chroma_db
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768
HOST=127.0.0.1
PORT=8000
APP_ENV=development

# Sandbox execution mode
# local: run code in-process (current behavior)
# remote: forward execution to a separate sandbox service
SANDBOX_EXECUTION_MODE=local
SANDBOX_API_URL=
SANDBOX_API_KEY=
SANDBOX_API_TIMEOUT_SECONDS=35
